<%
  settings_tabs = [
    { label: t("settings.tabs.general",       default: "Общие"),          path: settings_general_path,             icon: "settings" },
    { label: t("settings.tabs.ai",            default: "AI ассистент"),   path: settings_ai_path,                  icon: "trending" },
    { label: t("settings.tabs.notifications"),    path: settings_notification_path,        icon: "calendar" },
    { label: t("settings.tabs.sso",           default: "SSO"),            path: settings_sso_path,                 icon: "shield"   },
    { label: t("settings.tabs.api",           default: "API токены"),     path: settings_api_token_path,           icon: "file"     },
    { label: t("settings.tabs.kb",            default: "База знаний"),    path: settings_knowledge_articles_path,  icon: "book"     },
    { label: t("settings.tabs.price_lists",   default: "Прайс-листы"),   path: settings_price_lists_path,         icon: "briefcase" },
    { label: t("settings.tabs.payments"),      path: settings_payment_path,             icon: "file" },
    { label: t("settings.tabs.chat"),          path: settings_chat_path,                icon: "calendar" },
    { label: t("settings.tabs.languages"),     path: settings_languages_path,           icon: "globe" },
    { label: t("settings.tabs.translations"), path: settings_translations_path,        icon: "book" }
  ]
%>

<nav class="section-tabs mb-4">
  <% settings_tabs.each do |tab| %>
    <%= link_to tab[:path], class: "section-tabs__item #{'is-active' if current_page?(tab[:path])}" do %>
      <%= render "shared/icons/#{tab[:icon]}" rescue "" %>
      <span><%= tab[:label] %></span>
    <% end %>
  <% end %>
</nav>
