<% content_for :title, t("navigation.customers", default: "Клиенты") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= t("navigation.admin", default: "Администрирование") %></div>
    <h1 class="page-header__title m-0"><%= t("navigation.customers", default: "Клиенты") %></h1>
    <p class="page-header__subtitle m-0"><%= t("customers.summary", default: "%{count} клиентов", count: @customers.size) %></p>
  </div>
  <div class="page-header__actions">
    <%= link_to "+ #{t('customers.new', default: 'Добавить клиента')}", new_customer_path, class: "btn btn-primary" %>
  </div>
</header>

<% if @customers.any? %>
  <div class="card-apple card-apple--flush">
    <% @customers.each do |c| %>
      <%= link_to edit_customer_path(c), class: "ticket-row-tr" do %>
        <div class="ticket-row-tr__main">
          <div class="d-flex align-items-center gap-3">
            <span class="avatar-apple"><%= c.email.first(2).upcase %></span>
            <div>
              <div class="ticket-row-tr__subject"><%= c.display_name %></div>
              <div class="ticket-row-tr__meta">
                <span><%= c.email %></span>
                <% if c.external_id.present? %>
                  <span>·</span>
                  <span><%= c.external_provider %> id: <%= c.external_id %></span>
                <% end %>
              </div>
            </div>
          </div>
        </div>
        <div class="ticket-row-tr__pills">
          <span class="pill pill--neutral"><%= t("roles.customer", default: "Клиент") %></span>
          <% if c.locale.present? %><span class="pill pill--info"><%= c.locale.upcase %></span><% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="card-apple">
    <div class="empty-state">
      <h3 class="empty-state__title"><%= t("customers.empty", default: "Клиентов пока нет") %></h3>
      <p class="footnote text-secondary-apple"><%= t("customers.empty_hint", default: "Клиенты появятся автоматически через SSO или email-форму") %></p>
      <%= link_to "+ #{t('customers.new', default: 'Добавить вручную')}", new_customer_path, class: "btn btn-primary mt-2" %>
    </div>
  </div>
<% end %>
