<%= form_with model: customer, url: (customer.new_record? ? customers_path : customer_path(customer)), class: "card-apple" do |f| %>
  <% if customer.errors.any? %>
    <div class="alert alert-danger mb-3"><%= customer.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :name, t("users.name"), class: "form-label" %>
      <%= f.text_field :name, required: true, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :email, t("users.email"), class: "form-label" %>
      <%= f.email_field :email, required: true, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :locale, t("users.locale"), class: "form-label" %>
      <%= f.select :locale,
                   TriageLocales::AVAILABLE.map { |l| [ l[:native_name], l[:code] ] },
                   {}, { class: "form-select", data: { controller: "apple-select" } } %>
    </div>
    <div class="col-md-6">
      <%= f.label :external_id, t("customers.external_id"), class: "form-label" %>
      <%= f.text_field :external_id, class: "form-control",
                        placeholder: t("customers.external_id_hint") %>
    </div>
    <div class="col-12">
      <%= f.label :staff_notes, t("customers.staff_notes"), class: "form-label" %>
      <%= f.text_area :staff_notes, rows: 3, class: "form-control",
          placeholder: t("customers.staff_notes_hint") %>
      <div class="footnote text-tertiary mt-1"><%= t("customers.staff_notes_visibility") %></div>
    </div>
  </div>

  <div class="d-flex gap-2 justify-content-end mt-3">
    <%= link_to t("common.cancel"), customers_path, class: "btn btn-ghost" %>
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
  </div>
<% end %>
