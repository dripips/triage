<%
  is_mine   = defined?(current_user) && current_user && conversation_message.author == current_user rescue false
  is_system = conversation_message.system?
  is_ai     = conversation_message.ai_suggestion?
%>
<div id="<%= dom_id(conversation_message) %>"
     class="chat-bubble-tr <%= 'chat-bubble-tr--mine' if is_mine %> <%= 'chat-bubble-tr--system' if is_system %> <%= 'chat-bubble-tr--ai' if is_ai %> <%= 'chat-bubble-tr--internal' if conversation_message.internal %>">
  <% if is_system %>
    <div class="chat-bubble-tr__sys-line">
      <span><%= conversation_message.body %></span>
      <span class="chat-bubble-tr__time"><%= conversation_message.created_at.strftime("%H:%M") %></span>
    </div>
  <% else %>
    <% unless is_mine %>
      <div class="chat-bubble-tr__avatar">
        <span class="avatar-apple avatar-apple--sm">
          <%= (conversation_message.author&.respond_to?(:email) ? conversation_message.author.email : "?").to_s.first(2).upcase %>
        </span>
      </div>
    <% end %>
    <div class="chat-bubble-tr__cloud">
      <% unless is_mine %>
        <div class="chat-bubble-tr__name">
          <%= conversation_message.author&.respond_to?(:display_name) ? conversation_message.author.display_name : I18n.t("system_user") %>
          <% if conversation_message.internal %><span class="pill pill--warning pill--sm"><%= I18n.t("chat.internal_short") %></span><% end %>
          <% if is_ai %><span class="pill pill--info pill--sm">AI</span><% end %>
        </div>
      <% end %>
      <div class="chat-bubble-tr__text"><%= simple_format(conversation_message.body) %></div>
      <div class="chat-bubble-tr__footer">
        <% if conversation_message.internal && is_mine %><span class="pill pill--warning pill--sm"><%= I18n.t("chat.internal_short") %></span><% end %>
        <span class="chat-bubble-tr__time"><%= conversation_message.created_at.strftime("%H:%M") %></span>
        <% if is_mine %>
          <span class="chat-bubble-tr__read" title="<%= conversation_message.read_by.except(conversation_message.author_id.to_s).any? ? I18n.t('chat.read') : I18n.t('chat.delivered') %>">
            <%= conversation_message.read_by.except(conversation_message.author_id.to_s).any? ? "✓✓" : "✓" %>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
