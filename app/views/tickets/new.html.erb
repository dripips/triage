<% content_for :title, t("tickets.new", default: "Новый тикет") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= link_to "← #{t('tickets.title', default: 'Тикеты')}", tickets_path %></div>
    <h1 class="page-header__title m-0"><%= t("tickets.new", default: "Новый тикет") %></h1>
  </div>
</header>

<%= form_with model: @ticket, class: "card-apple" do |f| %>
  <% if @ticket.errors.any? %>
    <div class="alert alert-danger mb-3"><%= @ticket.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="mb-3">
    <%= f.label :ticket_type_id, t("tickets.type", default: "Тип"), class: "form-label" %>
    <%= f.collection_select :ticket_type_id,
                            TicketType.where(company: current_company).active_types,
                            :id, :name,
                            { include_blank: false },
                            { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :subject, t("tickets.subject", default: "Тема"), class: "form-label" %>
    <%= f.text_field :subject, required: true, autofocus: true, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, t("tickets.description", default: "Описание"), class: "form-label" %>
    <%= f.text_area :description, rows: 6, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :priority, t("tickets.priority_label", default: "Приоритет"), class: "form-label" %>
    <%= f.select :priority,
                 Ticket.priorities.keys.map { |p| [ t("tickets.priority.#{p}", default: p.humanize), p ] },
                 {}, { class: "form-select" } %>
  </div>

  <div class="d-flex gap-2 justify-content-end">
    <%= link_to t("common.cancel", default: "Отмена"), tickets_path, class: "btn btn-ghost" %>
    <%= f.submit t("common.create", default: "Создать"), class: "btn btn-primary" %>
  </div>
<% end %>
