<% content_for :title, t("tickets.title") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= t("navigation.workspace") %></div>
    <h1 class="page-header__title m-0"><%= t("tickets.title") %></h1>
    <p class="page-header__subtitle m-0">
      <%= t("tickets.summary", open: @open_count, closed: @closed_count) %>
    </p>
  </div>
  <div class="page-header__actions">
    <%= link_to "+ #{t('tickets.new', default: 'Новый тикет')}", new_ticket_path, class: "btn btn-primary" %>
  </div>
</header>

<%# ── Scope chips ── %>
<div class="filter-bar-tr">
  <%= link_to t("tickets.scope_all",    default: "Все"),       tickets_path(filter_params.except(:scope)),                   class: "filter-chip-tr #{'active' if params[:scope].blank?}" %>
  <%= link_to t("tickets.scope_mine",   default: "Мои"),       tickets_path(filter_params.merge(scope: "mine")),    class: "filter-chip-tr #{'active' if params[:scope] == 'mine'}" %>
  <%= link_to t("tickets.scope_open",   default: "Открытые"),  tickets_path(filter_params.merge(scope: "open")),    class: "filter-chip-tr #{'active' if params[:scope] == 'open'}" %>
  <%= link_to t("tickets.scope_closed"),  tickets_path(filter_params.merge(scope: "closed")),  class: "filter-chip-tr #{'active' if params[:scope] == 'closed'}" %>
</div>

<%# ── Advanced filters ── %>
<details class="mb-3" <%= "open" if filter_active? %>>
  <summary class="btn btn-ghost btn-sm"><%= t("tickets.filters") %> <%= "●" if filter_active? %></summary>
  <%= form_with url: tickets_path, method: :get, class: "card-apple mt-2 p-3" do |f| %>
    <%= hidden_field_tag :scope, params[:scope] if params[:scope].present? %>
    <div class="row g-3">
      <div class="col-md-3">
        <%= f.label :ticket_type_id, t("tickets.type"), class: "form-label" %>
        <%= f.select :ticket_type_id,
            TicketType.where(company: current_company).active_types.map { |tt| [tt.name, tt.id] },
            { include_blank: t("common.all"), selected: params[:ticket_type_id] },
            { class: "form-select form-select-sm", data: { controller: "apple-select" } } %>
      </div>
      <div class="col-md-3">
        <%= f.label :priority, t("tickets.priority_label"), class: "form-label" %>
        <%= f.select :priority,
            Ticket.priorities.keys.map { |p| [t("tickets.priority.#{p}", default: p.humanize), p] },
            { include_blank: t("common.all"), selected: params[:priority] },
            { class: "form-select form-select-sm", data: { controller: "apple-select" } } %>
      </div>
      <div class="col-md-3">
        <%= f.label :assignee_id, t("tickets.assignee"), class: "form-label" %>
        <%= f.select :assignee_id,
            User.kept.staff_users.where(company: current_company).map { |u| [u.display_name, u.id] },
            { include_blank: t("common.all"), selected: params[:assignee_id] },
            { class: "form-select form-select-sm", data: { controller: "apple-select" } } %>
      </div>
      <div class="col-md-3 d-flex align-items-end gap-2">
        <%= f.submit t("tickets.apply_filters"), class: "btn btn-primary btn-sm" %>
        <%= link_to t("tickets.reset_filters"), tickets_path, class: "btn btn-ghost btn-sm" %>
      </div>
    </div>
  <% end %>
</details>

<%# ── Ticket list ── %>
<% if @tickets.any? %>
  <div class="card-apple card-apple--flush">
    <% @tickets.each do |ticket| %>
      <%= link_to ticket_path(ticket), class: "ticket-row-tr" do %>
        <div class="ticket-row-tr__main">
          <div class="ticket-row-tr__subject">
            <span class="ticket-row-tr__id">#<%= ticket.id %></span>
            <%= ticket.subject %>
          </div>
          <div class="ticket-row-tr__meta">
            <span class="pill pill--neutral"><%= ticket.ticket_type.name %></span>
            <span>·</span>
            <span><%= ticket.reporter&.display_name || t("tickets.anonymous") %></span>
            <span>·</span>
            <span><%= time_ago_in_words(ticket.created_at) %> <%= t("common.ago") %></span>
            <% if ticket.assignee %><span>·</span><span><%= ticket.assignee.display_name %></span><% end %>
          </div>
        </div>
        <div class="ticket-row-tr__pills">
          <% if    ticket.urgent? %><span class="pill pill--danger">⚡ <%= t("tickets.priority.urgent") %></span>
          <% elsif ticket.high?   %><span class="pill pill--warning"><%= t("tickets.priority.high") %></span>
          <% elsif ticket.low?    %><span class="pill pill--neutral"><%= t("tickets.priority.low") %></span>
          <% end %>
          <span class="pill pill--<%= ticket.closed? ? 'success' : 'info' %>">
            <%= t("ticket_states.#{ticket.status}", default: ticket.status.humanize) %>
          </span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="card-apple">
    <div class="empty-state">
      <h3 class="empty-state__title"><%= t("tickets.no_tickets") %></h3>
      <p class="footnote text-secondary-apple"><%= t("tickets.no_tickets_hint") %></p>
      <%= link_to "+ #{t('tickets.new', default: 'Новый тикет')}", new_ticket_path, class: "btn btn-primary mt-2" %>
    </div>
  </div>
<% end %>
