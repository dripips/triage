<% content_for :title, @ticket.subject %>

<header class="page-header">
  <div>
    <div class="subtitle">
      <%= link_to "← #{t('tickets.title', default: 'Tickets')}", tickets_path %>
    </div>
    <h1><%= @ticket.subject %></h1>
    <div class="subtitle">
      <span class="pill pill--<%= @ticket.closed? ? 'green' : 'blue' %>"><%= @ticket.status %></span>
      <span class="pill"><%= @ticket.ticket_type.name %></span>
      <% if @ticket.urgent? %><span class="pill pill--red">urgent</span><% end %>
      <% if @ticket.high?   %><span class="pill pill--orange">high</span><% end %>
      <% if @ticket.low?    %><span class="pill">low</span><% end %>
      · <%= t("tickets.reporter", default: "Reporter") %>: <%= @ticket.reporter&.email || "anonymous" %>
      · <%= t("tickets.assignee", default: "Assignee") %>: <%= @ticket.assignee&.email || "unassigned" %>
    </div>
  </div>
</header>

<div class="card">
  <p style="white-space: pre-wrap;"><%= @ticket.description %></p>
</div>

<% if @transitions.any? %>
  <div class="card" style="margin-top: 16px;">
    <h3 style="margin: 0 0 12px;"><%= t("tickets.workflow", default: "Workflow") %></h3>
    <% @transitions.each do |event, _cfg| %>
      <%= button_to event.humanize,
                    transition_ticket_path(@ticket, event: event),
                    method: :post,
                    class: "btn btn-ghost",
                    style: "margin-right: 8px;" %>
    <% end %>
  </div>
<% end %>

<div class="card" style="margin-top: 16px;">
  <h3 style="margin: 0 0 12px;"><%= t("tickets.comments", default: "Comments") %> (<%= @comments.size %>)</h3>

  <% if @comments.any? %>
    <% @comments.each do |c| %>
      <div style="padding: 10px 0; border-top: 1px solid var(--separator);">
        <div style="font-size: 12px; color: var(--label-3); margin-bottom: 4px;">
          <strong><%= c.author&.respond_to?(:email) ? c.author.email : "system" %></strong>
          · <%= l(c.created_at, format: :short) rescue c.created_at.to_s %>
          <% if c.internal %><span class="pill pill--orange">internal</span><% end %>
        </div>
        <div style="white-space: pre-wrap;"><%= c.body %></div>
      </div>
    <% end %>
  <% else %>
    <div class="empty-state" style="padding: 20px;">No comments yet</div>
  <% end %>
</div>
