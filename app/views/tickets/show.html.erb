<% content_for :title, @ticket.subject %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow">
      <%= link_to "← #{t('tickets.title', default: 'Тикеты')}", tickets_path %>
    </div>
    <h1 class="page-header__title m-0">#<%= @ticket.id %> · <%= @ticket.subject %></h1>
    <div class="ticket-meta mt-2">
      <span class="pill pill--<%= @ticket.closed? ? 'success' : 'info' %>">
        <%= t("ticket_states.#{@ticket.status}", default: @ticket.status.humanize) %>
      </span>
      <span class="pill pill--neutral"><%= @ticket.ticket_type.name %></span>
      <% if    @ticket.urgent? %><span class="pill pill--danger">⚡ urgent</span>
      <% elsif @ticket.high?   %><span class="pill pill--warning">high</span>
      <% elsif @ticket.low?    %><span class="pill pill--neutral">low</span>
      <% end %>
    </div>
    <p class="footnote text-secondary-apple m-0 mt-2">
      <%= t("tickets.reporter", default: "Кем создан") %>:
      <strong><%= @ticket.reporter&.display_name || t("tickets.anonymous", default: "аноним") %></strong>
      ·
      <%= t("tickets.assignee", default: "Исполнитель") %>:
      <strong><%= @ticket.assignee&.display_name || t("tickets.unassigned", default: "не назначен") %></strong>
    </p>
  </div>
</header>

<%= turbo_frame_tag dom_id(@ticket) do %>
  <div class="card-apple mb-3">
    <p class="m-0" style="white-space: pre-wrap;"><%= @ticket.description %></p>
  </div>

  <% if @transitions.any? %>
    <div class="card-apple mb-3">
      <div class="card-apple__header">
        <h3 class="card-apple__title m-0"><%= t("tickets.workflow", default: "Workflow") %></h3>
      </div>
      <div class="d-flex gap-2 flex-wrap mt-2">
        <% @transitions.each do |event, _cfg| %>
          <%= button_to t("ticket_events.#{event}", default: event.to_s.humanize),
                        transition_ticket_path(@ticket, event: event),
                        method: :post,
                        class: "btn btn-soft btn-sm",
                        form: { class: "d-inline-block" } %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<div class="card-apple">
  <div class="card-apple__header">
    <h3 class="card-apple__title m-0">
      <%= t("tickets.comments", default: "Комментарии") %>
      <span class="pill pill--neutral ms-2" id="comments-count"><%= @comments.size %></span>
    </h3>
  </div>

  <%= turbo_frame_tag "comments" do %>
    <div id="comments-list">
      <% if @comments.any? %>
        <%= render @comments %>
      <% else %>
        <p class="footnote text-secondary-apple m-0 py-3 text-center">
          <%= t("tickets.no_comments", default: "Пока нет комментариев") %>
        </p>
      <% end %>
    </div>
  <% end %>

  <%= render "ticket_comments/form", ticket: @ticket, comment: @new_comment %>
</div>
