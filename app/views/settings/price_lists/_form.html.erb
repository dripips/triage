<%= form_with model: [:settings, price_list], class: "card-apple" do |f| %>
  <% if price_list.errors.any? %>
    <div class="alert alert-danger mb-3"><%= price_list.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.label :name, t("price_lists.name", default: "Название"), class: "form-label" %>
      <%= f.text_field :name, required: true, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <div class="form-check form-switch mt-4">
        <%= f.check_box :active, class: "form-check-input", role: "switch" %>
        <%= f.label :active, t("price_lists.is_active", default: "Активен"), class: "form-check-label" %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 justify-content-end mt-3">
    <%= link_to t("common.cancel", default: "Отмена"), settings_price_lists_path, class: "btn btn-ghost" %>
    <%= f.submit t("common.save", default: "Сохранить"), class: "btn btn-primary" %>
  </div>
<% end %>

<% if price_list.persisted? && defined?(@items) %>
  <div class="card-apple mt-3">
    <div class="card-apple__header d-flex justify-content-between align-items-center">
      <h3 class="card-apple__title m-0"><%= t("price_lists.items", default: "Позиции") %></h3>
    </div>

    <% if @items.any? %>
      <table class="table mt-2">
        <thead>
          <tr>
            <th><%= t("price_items.name", default: "Название") %></th>
            <th><%= t("price_items.price", default: "Цена") %></th>
            <th><%= t("price_items.status", default: "Статус") %></th>
          </tr>
        </thead>
        <tbody>
          <% @items.each do |item| %>
            <tr>
              <td>
                <strong><%= item.name %></strong>
                <% if item.description.present? %>
                  <div class="footnote text-tertiary"><%= item.description.truncate(80) %></div>
                <% end %>
              </td>
              <td class="text-mono"><%= item.formatted_price %></td>
              <td>
                <% if item.active %>
                  <span class="pill pill--success"><%= t("price_items.active_label", default: "активна") %></span>
                <% else %>
                  <span class="pill pill--neutral"><%= t("price_items.inactive", default: "неактивна") %></span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="footnote text-secondary-apple mt-2 mb-0"><%= t("price_items.empty", default: "Позиции добавляются через rails console (CRUD в v0.5)") %></p>
    <% end %>
  </div>
<% end %>
