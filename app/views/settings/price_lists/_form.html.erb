<%
  sym = AppSetting.fetch(company: current_company, category: "payments").get("currency") || "RUB"
  currency_symbol = { "RUB" => "₽", "USD" => "$", "EUR" => "€" }[sym] || sym
%>

<%= form_with model: [:settings, price_list], class: "card-apple" do |f| %>
  <% if price_list.errors.any? %>
    <div class="alert alert-danger mb-3"><%= price_list.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.label :name, t("price_lists.name"), class: "form-label" %>
      <%= f.text_field :name, required: true, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <div class="form-check form-switch mt-4">
        <%= f.check_box :active, class: "form-check-input", role: "switch" %>
        <%= f.label :active, t("price_lists.is_active"), class: "form-check-label" %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 justify-content-end mt-3">
    <%= link_to t("common.cancel"), settings_price_lists_path, class: "btn btn-ghost" %>
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
  </div>
<% end %>

<% if price_list.persisted? %>
  <div class="card-apple mt-3">
    <div class="card-apple__header d-flex justify-content-between align-items-center">
      <h3 class="card-apple__title m-0"><%= t("price_lists.items") %></h3>
    </div>

    <% items = price_list.price_items.by_position %>
    <% if items.any? %>
      <div class="d-flex flex-column gap-2 mt-3">
        <% items.each do |item| %>
          <%= form_with model: [:settings, price_list, item], class: "d-flex gap-2 align-items-center p-2",
              style: "border-bottom: 1px solid var(--ds-separator);" do |f| %>
            <div style="flex:3;">
              <%= f.text_field :name, class: "form-control form-control-sm", placeholder: t("price_items.name") %>
            </div>
            <div style="flex:2;">
              <%= f.text_field :description, class: "form-control form-control-sm", placeholder: t("price_items.description") %>
            </div>
            <div style="flex:1;">
              <%= f.number_field :amount_rub, value: item.amount_cents / 100.0, step: 0.01, min: 0,
                  class: "form-control form-control-sm text-end", placeholder: currency_symbol %>
            </div>
            <div style="flex:0 0 auto;" class="d-flex gap-1">
              <%= f.submit "✓", class: "btn btn-soft btn-sm", title: t("common.save") %>
              <%= button_to "✕", settings_price_list_price_item_path(price_list, item), method: :delete,
                  class: "btn btn-ghost btn-sm", form: { class: "d-inline" }, title: t("common.delete") %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Add new item %>
    <%= form_with model: [:settings, price_list, PriceItem.new], url: settings_price_list_price_items_path(price_list),
        class: "d-flex gap-2 align-items-center mt-3 p-2", style: "background: var(--ds-fill-tertiary); border-radius: var(--ds-radius-md);" do |f| %>
      <div style="flex:3;">
        <%= f.text_field :name, class: "form-control form-control-sm", placeholder: t("price_items.new_placeholder", default: "New item name"), required: true %>
      </div>
      <div style="flex:2;">
        <%= f.text_field :description, class: "form-control form-control-sm", placeholder: t("price_items.description") %>
      </div>
      <div style="flex:1;">
        <%= f.number_field :amount_rub, value: 0, step: 0.01, min: 0,
            class: "form-control form-control-sm text-end", placeholder: currency_symbol %>
      </div>
      <div style="flex:0 0 auto;">
        <%= f.submit "+ #{t('price_items.add', default: 'Add')}", class: "btn btn-primary btn-sm" %>
      </div>
    <% end %>
  </div>
<% end %>
