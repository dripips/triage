<% content_for :title, t("settings.tabs.notifications") %>

<header class="page-header">
  <div><h1 class="page-header__title m-0"><%= t("settings.title") %></h1></div>
</header>

<%= render "shared/settings_tabs" %>

<%= form_with model: @setting, url: settings_notification_path, method: :patch, class: "card-apple" do |f| %>
  <div class="card-apple__header">
    <h3 class="card-apple__title m-0"><%= t("settings.notifications.title") %></h3>
    <p class="card-apple__subtitle m-0"><%= t("settings.notifications.subtitle") %></p>
  </div>

  <div class="row g-3 mt-2">
    <div class="col-12">
      <div class="form-check form-switch">
        <%= f.check_box :in_app_enabled, checked: @setting.get("in_app_enabled") != "0", class: "form-check-input", role: "switch" %>
        <%= f.label :in_app_enabled, t("settings.notifications.in_app"), class: "form-check-label" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="form-check form-switch">
        <%= f.check_box :email_on_new_ticket, checked: @setting.get("email_on_new_ticket") != "0", class: "form-check-input", role: "switch" %>
        <%= f.label :email_on_new_ticket, t("settings.notifications.email_new"), class: "form-check-label" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="form-check form-switch">
        <%= f.check_box :email_on_comment, checked: @setting.get("email_on_comment") != "0", class: "form-check-input", role: "switch" %>
        <%= f.label :email_on_comment, t("settings.notifications.email_comment"), class: "form-check-label" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="form-check form-switch">
        <%= f.check_box :email_on_transition, checked: @setting.get("email_on_transition") == "1", class: "form-check-input", role: "switch" %>
        <%= f.label :email_on_transition, t("settings.notifications.email_transition"), class: "form-check-label" %>
      </div>
    </div>
    <div class="col-md-6">
      <%= f.label :digest_frequency, t("settings.notifications.digest"), class: "form-label" %>
      <%= f.select :digest_frequency,
                   [
                     [t("settings.notifications.digest_none"), "none"],
                     [t("settings.notifications.digest_daily"), "daily"],
                     [t("settings.notifications.digest_weekly"), "weekly"]
                   ],
                   { selected: @setting.get("digest_frequency") || "none" },
                   { class: "form-select", data: { controller: "apple-select" } } %>
    </div>
  </div>

  <hr class="my-3">

  <h5 class="mb-3">Telegram</h5>
  <div class="row g-3">
    <div class="col-md-2">
      <div class="form-check form-switch">
        <%= f.check_box :telegram_enabled, checked: @setting.get("telegram_enabled") == "1", class: "form-check-input", role: "switch" %>
        <%= f.label :telegram_enabled, t("settings.notifications.telegram_enabled"), class: "form-check-label" %>
      </div>
    </div>
    <div class="col-md-5">
      <%= f.label :telegram_bot_token, t("settings.notifications.telegram_token"), class: "form-label" %>
      <%= f.text_field :telegram_bot_token, value: @setting.get("telegram_bot_token"), class: "form-control text-mono", style: "font-size:13px" %>
    </div>
    <div class="col-md-5">
      <%= f.label :telegram_chat_id, t("settings.notifications.telegram_chat_id"), class: "form-label" %>
      <%= f.text_field :telegram_chat_id, value: @setting.get("telegram_chat_id"), class: "form-control" %>
    </div>
  </div>

  <hr class="my-3">

  <h5 class="mb-3">Slack</h5>
  <div class="row g-3">
    <div class="col-md-2">
      <div class="form-check form-switch">
        <%= f.check_box :slack_enabled, checked: @setting.get("slack_enabled") == "1", class: "form-check-input", role: "switch" %>
        <%= f.label :slack_enabled, t("settings.notifications.slack_enabled"), class: "form-check-label" %>
      </div>
    </div>
    <div class="col-md-10">
      <%= f.label :slack_webhook_url, t("settings.notifications.slack_webhook"), class: "form-label" %>
      <%= f.text_field :slack_webhook_url, value: @setting.get("slack_webhook_url"), class: "form-control text-mono", style: "font-size:13px",
          placeholder: "https://hooks.slack.com/services/..." %>
    </div>
  </div>

  <div class="d-flex justify-content-end mt-3">
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
  </div>
<% end %>
