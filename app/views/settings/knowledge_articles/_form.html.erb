<%= form_with model: [:settings, article], class: "card-apple" do |f| %>
  <% if article.errors.any? %>
    <div class="alert alert-danger mb-3"><%= article.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.label :title, t("knowledge.title_field"), class: "form-label" %>
      <%= f.text_field :title, required: true, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :ticket_type_id, t("knowledge.ticket_type"), class: "form-label" %>
      <%= f.collection_select :ticket_type_id,
                              TicketType.where(company: current_company).active_types, :id, :name,
                              { include_blank: t("knowledge.all_types") },
                              { class: "form-select", data: { controller: "apple-select" } } %>
    </div>
    <div class="col-12">
      <%= f.label :body, t("knowledge.body"), class: "form-label" %>
      <%= f.text_area :body, rows: 12, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :position, t("knowledge.position"), class: "form-label" %>
      <%= f.number_field :position, class: "form-control", min: 0 %>
    </div>
    <div class="col-12">
      <div class="form-check form-switch">
        <%= f.check_box :published, class: "form-check-input", role: "switch" %>
        <%= f.label :published, t("knowledge.publish"), class: "form-check-label" %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 justify-content-end mt-3">
    <%= link_to t("common.cancel"), settings_knowledge_articles_path, class: "btn btn-ghost" %>
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
  </div>
<% end %>
