<% content_for :title, t("notifications.title", default: "Уведомления") %>

<header class="page-header">
  <div>
    <h1 class="page-header__title m-0"><%= t("notifications.title", default: "Уведомления") %></h1>
    <p class="page-header__subtitle m-0"><%= t("notifications.unread_count", default: "%{count} непрочитанных", count: @notifications.unread.count) %></p>
  </div>
  <div class="page-header__actions">
    <%= button_to t("notifications.mark_all_read", default: "Прочитать все"),
                  mark_read_notifications_path, method: :post, class: "btn btn-ghost" %>
  </div>
</header>

<% if @notifications.any? %>
  <div class="card-apple card-apple--flush">
    <% @notifications.each do |n| %>
      <%= link_to (n.url.presence || "#"), class: "ticket-row-tr #{'fw-bold' unless n.read?}" do %>
        <div class="ticket-row-tr__main">
          <div class="ticket-row-tr__subject">
            <% unless n.read? %><span class="notif-dot-tr"></span><% end %>
            <%= n.message %>
          </div>
          <div class="ticket-row-tr__meta">
            <span><%= time_ago_in_words(n.created_at) %> <%= t("common.ago", default: "назад") %></span>
            <% if n.actor.respond_to?(:display_name) %><span>·</span><span><%= n.actor.display_name %></span><% end %>
          </div>
        </div>
        <div class="ticket-row-tr__pills">
          <span class="pill pill--<%= n.read? ? 'neutral' : 'info' %>"><%= t("notifications.actions.#{n.action}", default: n.action.humanize) %></span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="card-apple">
    <div class="empty-state">
      <h3 class="empty-state__title"><%= t("notifications.empty", default: "Нет уведомлений") %></h3>
    </div>
  </div>
<% end %>
