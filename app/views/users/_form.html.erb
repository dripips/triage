<%= form_with model: user, class: "card-apple" do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger mb-3"><%= user.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :name, t("users.name"), class: "form-label" %>
      <%= f.text_field :name, required: true, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :email, t("users.email"), class: "form-label" %>
      <%= f.email_field :email, required: true, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :role, t("users.role"), class: "form-label" %>
      <%= f.select :role,
                   User.roles.keys.map { |r| [ I18n.t("roles.#{r}", default: r.humanize), r ] },
                   {}, { class: "form-select", data: { controller: "apple-select" } } %>
    </div>
    <div class="col-md-6">
      <%= f.label :locale, t("users.locale"), class: "form-label" %>
      <%= f.select :locale,
                   TriageLocales::AVAILABLE.map { |l| [ l[:native_name], l[:code] ] },
                   {}, { class: "form-select", data: { controller: "apple-select" } } %>
    </div>
    <% if user.new_record? %>
      <div class="col-md-6">
        <%= f.label :password, t("users.password"), class: "form-label" %>
        <%= f.password_field :password, class: "form-control",
                              placeholder: t("users.password_hint") %>
      </div>
    <% end %>
  </div>

  <div class="d-flex gap-2 justify-content-end mt-3">
    <%= link_to t("common.cancel"), users_path, class: "btn btn-ghost" %>
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
  </div>
<% end %>
