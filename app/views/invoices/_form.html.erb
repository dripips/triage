<%= form_with model: invoice, class: "card-apple", data: { controller: "invoice-items" } do |f| %>
  <% if invoice.errors.any? %>
    <div class="alert alert-danger mb-3"><%= invoice.errors.full_messages.to_sentence %></div>
  <% end %>

  <%= f.hidden_field :ticket_id %>

  <div class="row g-3 mb-3">
    <div class="col-md-3">
      <%= f.label :status, t("invoices.status_label", default: "Статус"), class: "form-label" %>
      <%= f.select :status, Invoice.statuses.keys.map { |s| [t("invoices.status.#{s}", default: s.humanize), s] },
                   {}, { class: "form-select" } %>
    </div>
    <div class="col-md-3">
      <%= f.label :currency, t("invoices.currency", default: "Валюта"), class: "form-label" %>
      <%= f.select :currency, [["RUB ₽", "RUB"], ["USD $", "USD"], ["EUR €", "EUR"]], {}, { class: "form-select" } %>
    </div>
    <div class="col-md-3">
      <%= f.label :discount_percent, t("invoices.discount", default: "Скидка %"), class: "form-label" %>
      <%= f.number_field :discount_percent, step: 0.5, min: 0, max: 100, class: "form-control" %>
    </div>
    <div class="col-md-3">
      <%= f.label :tax_percent, t("invoices.tax_label", default: "НДС %"), class: "form-label" %>
      <%= f.number_field :tax_percent, step: 0.5, min: 0, max: 50, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :due_at, t("invoices.due_at", default: "Оплатить до"), class: "form-label" %>
      <%= f.date_field :due_at, class: "form-control" %>
    </div>
  </div>

  <h4 class="card-apple__title mb-2"><%= t("invoices.items_title", default: "Позиции") %></h4>

  <div data-invoice-items-target="container">
    <% f.fields_for :invoice_items do |item_f| %>
      <div class="invoice-item-card card-apple p-3 mb-2" data-invoice-items-target="row">
        <div class="row g-2">
          <div class="col-md-5">
            <%= item_f.text_field :name, class: "form-control form-control-sm", placeholder: t("invoice_items.name", default: "Услуга / товар") %>
          </div>
          <div class="col-md-3">
            <%= item_f.text_field :description, class: "form-control form-control-sm", placeholder: t("invoice_items.description", default: "Описание") %>
          </div>
          <div class="col-md-1">
            <%= item_f.number_field :quantity, step: 0.01, min: 0, class: "form-control form-control-sm text-end", placeholder: t("invoice_items.qty", default: "Кол") %>
          </div>
          <div class="col-md-2">
            <%= item_f.number_field :unit_price_cents, step: 1, min: 0, class: "form-control form-control-sm text-end", placeholder: t("invoice_items.unit_price", default: "Цена") %>
          </div>
          <div class="col-md-1 d-flex align-items-center justify-content-end">
            <% if item_f.object.persisted? %>
              <%= item_f.hidden_field :_destroy, value: "0", class: "destroy-flag" %>
            <% end %>
            <button type="button" class="btn btn-ghost btn-sm" data-action="click->invoice-items#remove" title="Удалить">✕</button>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <template data-invoice-items-target="template">
    <div class="invoice-item-card card-apple p-3 mb-2" data-invoice-items-target="row">
      <div class="row g-2">
        <div class="col-md-5">
          <input type="text" name="invoice[invoice_items_attributes][NEW_IDX][name]" class="form-control form-control-sm" placeholder="<%= t('invoice_items.name', default: 'Услуга / товар') %>">
        </div>
        <div class="col-md-3">
          <input type="text" name="invoice[invoice_items_attributes][NEW_IDX][description]" class="form-control form-control-sm" placeholder="<%= t('invoice_items.description', default: 'Описание') %>">
        </div>
        <div class="col-md-1">
          <input type="number" name="invoice[invoice_items_attributes][NEW_IDX][quantity]" value="1" step="0.01" min="0" class="form-control form-control-sm text-end">
        </div>
        <div class="col-md-2">
          <input type="number" name="invoice[invoice_items_attributes][NEW_IDX][unit_price_cents]" value="0" step="1" min="0" class="form-control form-control-sm text-end">
        </div>
        <div class="col-md-1 d-flex align-items-center justify-content-end">
          <button type="button" class="btn btn-ghost btn-sm" data-action="click->invoice-items#remove">✕</button>
        </div>
      </div>
    </div>
  </template>

  <button type="button" class="btn btn-soft btn-sm mb-3" data-action="click->invoice-items#add">
    + <%= t("invoices.add_item", default: "Добавить позицию") %>
  </button>

  <div class="footnote text-tertiary mb-3">
    <%= t("invoices.price_hint", default: "Цена в копейках (100 коп = 1 ₽). Кол-во поддерживает дробные.") %>
  </div>

  <div class="mb-3">
    <%= f.label :notes, t("invoices.notes", default: "Примечания"), class: "form-label" %>
    <%= f.text_area :notes, rows: 3, class: "form-control", placeholder: t("invoices.notes_placeholder", default: "Условия оплаты, реквизиты, комментарии...") %>
  </div>

  <div class="d-flex gap-2 justify-content-end">
    <%= link_to t("common.cancel", default: "Отмена"), invoices_path, class: "btn btn-ghost" %>
    <%= f.submit t("common.save", default: "Сохранить"), class: "btn btn-primary" %>
  </div>
<% end %>
