<%= form_with model: invoice, class: "card-apple" do |f| %>
  <% if invoice.errors.any? %>
    <div class="alert alert-danger mb-3"><%= invoice.errors.full_messages.to_sentence %></div>
  <% end %>

  <%= f.hidden_field :ticket_id %>

  <div class="row g-3 mb-3">
    <div class="col-md-3">
      <%= f.label :status, t("invoices.status_label", default: "Статус"), class: "form-label" %>
      <%= f.select :status, Invoice.statuses.keys.map { |s| [t("invoices.status.#{s}", default: s.humanize), s] },
                   {}, { class: "form-select" } %>
    </div>
    <div class="col-md-3">
      <%= f.label :currency, t("invoices.currency", default: "Валюта"), class: "form-label" %>
      <%= f.select :currency, [["RUB ₽", "RUB"], ["USD $", "USD"], ["EUR €", "EUR"]], {}, { class: "form-select" } %>
    </div>
    <div class="col-md-3">
      <%= f.label :discount_percent, t("invoices.discount", default: "Скидка %"), class: "form-label" %>
      <%= f.number_field :discount_percent, step: 0.5, min: 0, max: 100, class: "form-control" %>
    </div>
    <div class="col-md-3">
      <%= f.label :tax_percent, t("invoices.tax_label", default: "НДС %"), class: "form-label" %>
      <%= f.number_field :tax_percent, step: 0.5, min: 0, max: 50, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :due_at, t("invoices.due_at", default: "Оплатить до"), class: "form-label" %>
      <%= f.date_field :due_at, class: "form-control" %>
    </div>
  </div>

  <h4 class="card-apple__title mb-2"><%= t("invoices.items_title", default: "Позиции") %></h4>

  <table class="table table-sm" id="invoice-items-table">
    <thead>
      <tr>
        <th style="width:35%"><%= t("invoice_items.name", default: "Название") %></th>
        <th style="width:25%"><%= t("invoice_items.description", default: "Описание") %></th>
        <th style="width:10%" class="text-end"><%= t("invoice_items.qty", default: "Кол-во") %></th>
        <th style="width:15%" class="text-end"><%= t("invoice_items.unit_price", default: "Цена (коп)") %></th>
        <th style="width:15%"></th>
      </tr>
    </thead>
    <tbody>
      <%= f.fields_for :invoice_items do |item_f| %>
        <tr class="invoice-item-row">
          <td><%= item_f.text_field :name, class: "form-control form-control-sm", placeholder: "Услуга / товар" %></td>
          <td><%= item_f.text_field :description, class: "form-control form-control-sm", placeholder: "Опционально" %></td>
          <td><%= item_f.number_field :quantity, step: 0.01, min: 0, class: "form-control form-control-sm text-end" %></td>
          <td><%= item_f.number_field :unit_price_cents, step: 1, min: 0, class: "form-control form-control-sm text-end" %></td>
          <td class="text-end">
            <% if item_f.object.persisted? %>
              <%= item_f.hidden_field :_destroy, value: "0", class: "destroy-flag" %>
              <button type="button" class="btn btn-ghost btn-sm" onclick="this.closest('tr').querySelector('.destroy-flag').value='1'; this.closest('tr').style.display='none'">✕</button>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="footnote text-tertiary mb-3">
    <%= t("invoices.price_hint", default: "Цена в копейках (1 руб = 100 коп, 1 USD = 100 центов). Кол-во поддерживает дробные значения.") %>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12">
      <%= f.label :notes, t("invoices.notes", default: "Примечания"), class: "form-label" %>
      <%= f.text_area :notes, rows: 3, class: "form-control", placeholder: t("invoices.notes_placeholder", default: "Условия оплаты, реквизиты, комментарии...") %>
    </div>
  </div>

  <div class="d-flex gap-2 justify-content-end">
    <%= link_to t("common.cancel", default: "Отмена"), invoices_path, class: "btn btn-ghost" %>
    <%= f.submit t("common.save", default: "Сохранить"), class: "btn btn-primary" %>
  </div>
<% end %>
